---
import Layout from '../layouts/Layout.astro';
import Dashboard from '../components/Dashboard';
import ThemeToggle from '../components/ThemeToggle';

const user = Astro.locals.user;
const errorParam = Astro.url.searchParams.get('error');

let errorMessage = '';
if (errorParam === 'invalid_domain') {
  errorMessage = 'Acceso restringido. Solo se admiten correos corporativos con dominio @rpj.es.';
} else if (errorParam) {
  errorMessage = 'Ocurrió un error al intentar iniciar sesión. Por favor, vuelve a intentarlo.';
}
---

<Layout title="Acortador de Enlaces y QR | RPJ">
  {user ? (
    <Dashboard user={user} client:load />
  ) : (
    <div class="w-full max-w-md mx-auto p-8 bg-[#ffffff] dark:bg-[#121310] border border-[#edf0e8] dark:border-[#1c1d1a] rounded-2xl text-center space-y-6 shadow-xl relative overflow-hidden transition-colors duration-200">
      <!-- Top aesthetic bar -->
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-[#94C700]"></div>
      
      {/* Theme toggle corner positioning */}
      <div class="absolute top-4 right-4">
        <ThemeToggle client:load />
      </div>

      <div class="space-y-2">
        <div class="w-16 h-16 rounded-2xl bg-[#94C700]/10 border border-[#94C700]/30 flex items-center justify-center mx-auto text-[#94C700] mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link-2"><path d="M9 17H7A5 5 0 0 1 7 7h2"></path><path d="M15 7h2a5 5 0 0 1 0 10h-2"></path><line x1="8" x2="16" y1="12" y2="12"></line></svg>
        </div>
        <h1 class="text-[#1c1d1a] dark:text-white font-black text-2xl tracking-tight">Enlaces Cortos RPJ</h1>
        <p class="text-[#6d7067] dark:text-[#575855] text-sm">
          Generador interno de URLs acortadas y códigos QR para la Red de Pastoral Juvenil.
        </p>
      </div>

      {errorMessage && (
        <div class="p-4 bg-red-500/10 border border-red-500/20 text-red-600 dark:text-red-400 text-xs rounded-xl text-left leading-relaxed">
          {errorMessage}
        </div>
      )}

      <div class="pt-2">
        <a 
          href="/api/auth/login" 
          class="w-full flex items-center justify-center gap-3 py-3.5 bg-white dark:bg-white hover:bg-neutral-100 text-black font-bold rounded-xl transition cursor-pointer shadow-lg border border-neutral-200 dark:border-transparent"
        >
          <!-- Google Icon -->
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Iniciar sesión con Google
        </a>
        <div class="mt-4 flex items-center justify-center gap-1.5 text-[10px] text-[#6d7067] dark:text-[#575855] font-mono">
          <span>Acceso exclusivo para cuentas</span>
          <span class="text-[#94C700] font-bold">@rpj.es</span>
        </div>
      </div>
    </div>
  )}
</Layout>
